{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SpineForge X",
  "version": "0.2.9",
  "identifier": "com.spineforge.x",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SpineForge X",
        "width": 980,
        "height": 900,
        "minWidth": 720,
        "minHeight": 560,
        "decorations": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": [
      "export-presets/*"
    ],
    "icon": [
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE4OEEwRUE4QkUyOEVCMEYKUldRUDZ5aStxQTZLR0h1QU1NdjBiMlUydjZUNnJkNE56ajFuUlNIRmhuK0VaRXVZbWJEdTVrT2IK",
      "endpoints": [
        "https://gitlab.com/cuongondi/spineforge-x/-/releases/permalink/latest/downloads/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
