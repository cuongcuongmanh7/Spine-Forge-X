{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SpineForge X",
  "version": "0.3.9",
  "identifier": "com.spineforge.x",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SpineForge X",
        "width": 980,
        "height": 900,
        "minWidth": 720,
        "minHeight": 560,
        "decorations": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": [
      "export-presets/*"
    ],
    "icon": [
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE4OEEwRUE4QkUyOEVCMEYKUldRUDZ5aStxQTZLR0h1QU1NdjBiMlUydjZUNnJkNE56ajFuUlNIRmhuK0VaRXVZbWJEdTVrT2IK",
      "endpoints": [
        "https://github.com/cuongcuongmanh7/Spine-Forge-X/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
