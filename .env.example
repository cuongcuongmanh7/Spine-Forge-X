# Firebase web config for the sync metadata + thumbnail layer (see docs/sync.md ▸ "Bảo vệ dữ liệu").
# These are NOT secrets (Firebase web config is public by design; security is enforced by
# firestore.rules / storage.rules). Copy to `.env.local` and fill from:
#   Firebase Console ▸ Project settings ▸ General ▸ Your apps ▸ Web app ▸ SDK setup and configuration.
# Leave blank to disable the Firebase layer (the app still runs; sync/shared-thumbnails just stay off).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
